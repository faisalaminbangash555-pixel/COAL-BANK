; [6] CHANGE PIN
; =====================================================

doChangePin:

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    ; --- First: verify current PIN ---
    mov ah,09h
    lea dx,changePinVerifyMsg  ; "Enter Current PIN to Verify: "
    int 21h

    call flushKbBuffer         ; drain any leftover keystrokes
    call readMaskedPin         ; read current PIN into pinTemp

    ; Compare entered PIN against stored PIN for this user
    mov ax,pinTemp
    mov si,currentUserIndex
    shl si,1
    cmp ax,userPin_arr[si]
    jne changePinFail          ; wrong current PIN -> reject

    ; --- Current PIN verified: prompt for new PIN ---
    mov ah,09h
    lea dx,newPinMsg
    int 21h

    call flushKbBuffer         ; drain before new PIN entry
    call readMaskedPin         ; read new PIN into pinTemp

    ; Save new PIN into the user's slot
    mov ax,pinTemp
    mov si,currentUserIndex
    shl si,1
    mov userPin_arr[si],ax

    mov ah,09h
    lea dx,succesMsg
    int 21h

    ; Auto-logout: PIN changed, force re-authentication
    mov ah,09h
    lea dx,logoutMsg
    int 21h

    call pause
    jmp start                  ; return to main menu, user must login again

changePinFail:

    mov ah,09h
    lea dx,loginFailMsg        ; reuse "INVALID LOGIN DETAILS" banner
    int 21h
    call pause
    jmp userPanel

