; =====================================================
; [5] VIEW TRANSACTION HISTORY  (FULL - ALL RECORDS)
; =====================================================
; [FIX-2] Now loops through ALL recorded transactions
; for the current user (up to MAX_HIST entries) using
; the 2-D history arrays.
;
; The number of valid records = histCount_arr[user]
; BUT: because the ring buffer wraps at MAX_HIST,
; once histCount_arr reaches 0 again after wrap, we
; store the total valid count separately.
;
; For simplicity and reliability in EMU8086:
;   - We always display up to MAX_HIST (10) slots.
;   - Slots with type == 'N' are skipped (never used).
;   - Oldest entry is slot 0, newest is (count-1) % 10
;   - If count has NOT wrapped, display 0..(count-1).
;   - If count HAS wrapped (ring), display all 10 in
;     ring order; current histCount_arr value is the
;     index of the NEXT write slot (oldest record).
;
; To distinguish wrap vs no-wrap we use a separate
; histFull_arr (db MAX_USERS dup(0)).
; =====================================================

doHistory:

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ah,09h
    lea dx,historyHeader
    int 21h

    ; CX = total tx count for current user
    mov bx,currentUserIndex
    shl bx,1
    mov cx,histCount_arr[bx]   ; CX = next write slot index

    ; Check if ANY record exists: peek at slot 0 type
    mov ax,currentUserIndex
    mov bx,MAX_HIST
    mul bx                     ; AX = U*10  (DX destroyed, ok)
    mov si,ax                  ; SI = base flat byte index for this user

    ; If the VERY first slot is 'N' and count is 0 -> no history
    mov al,historyType_arr[si]
    cmp al,'N'
    jne  histHasData

    ; count == 0 means nothing ever written
    cmp cx,0
    jne  histHasData

    mov ah,09h
    lea dx,noHistoryMsg
    int 21h
    call pause
    jmp userPanel

histHasData:

    ; We now walk ALL 10 slots and print non-N entries.
    ; SI = flat base for this user (U*10), already computed.
    ; Walk slot 0 .. MAX_HIST-1:

    mov di,0                   ; DI = slot index 0..9

histWalkLoop:

    cmp di,MAX_HIST
    jge histWalkDone

    ; flat byte index = SI_base + DI
    mov bx,si
    add bx,di                  ; BX = flat byte index

    mov al,historyType_arr[bx]
    cmp al,'N'
    je  histNextSlot           ; skip empty slots

    ; ---- print separator ----
    push si
    push di
    push bx
    mov ah,09h
    lea dx,histSepLine
    int 21h
    pop bx
    pop di
    pop si

    ; ---- print type label and amount ----
    mov al,historyType_arr[bx]

    cmp al,'D'
    je  hist_printDep

    cmp al,'W'
    je  hist_printWth

    cmp al,'T'
    je  hist_printSnd

    cmp al,'R'
    je  hist_printRcv

    jmp histNextSlot

hist_printDep:
    push si
    push di
    push bx
    mov ah,09h
    lea dx,histTypeDepMsg
    int 21h
    pop bx
    pop di
    pop si
    jmp hist_printAmt

hist_printWth:
    push si
    push di
    push bx
    mov ah,09h
    lea dx,histTypeWthMsg
    int 21h
    pop bx
    pop di
    pop si
    jmp hist_printAmt

hist_printSnd:
    push si
    push di
    push bx
    mov ah,09h
    lea dx,histTypeSndMsg
    int 21h
    pop bx
    pop di
    pop si
    jmp hist_printAmt

hist_printRcv:
    push si
    push di
    push bx
    mov ah,09h
    lea dx,histTypeRcvMsg
    int 21h
    pop bx
    pop di
    pop si

hist_printAmt:

    ; word offset = flat_index * 2
    ; BX = flat byte index (still valid via stack round-trips above)
    push si
    push di
    push bx

    shl bx,1                   ; BX = word offset
    mov ax,historyAmt_arr[bx]
    call printNumber

    ; ---- print peer info if transfer ----
    ; Restore flat byte index
    pop bx                     ; BX = word offset (bx was shifted)
    push bx
    shr bx,1                   ; back to byte index
    mov al,historyType_arr[bx]

    cmp al,'T'
    je  hist_showToAcc

    cmp al,'R'
    je  hist_showFromAcc

    ; Deposit or Withdraw -> no peer
    pop bx
    pop di
    pop si
    jmp histNextSlot

hist_showToAcc:
    pop bx                     ; byte index
    push bx
    shl bx,1                   ; word offset
    mov ax,historyPeer_arr[bx] ; peer acc no
    pop bx
    pop di
    pop si

    push ax                    ; save peer acc no
    push si
    push di
    mov ah,09h
    lea dx,newline
    int 21h
    mov ah,09h
    lea dx,histToAcc
    int 21h
    pop di
    pop si
    pop ax
    call printNumber

    ; look up peer name
    call printPeerNameFromAX
    jmp histNextSlot

hist_showFromAcc:
    pop bx                     ; byte index
    push bx
    shl bx,1                   ; word offset
    mov ax,historyPeer_arr[bx] ; peer acc no
    pop bx
    pop di
    pop si

    push ax
    push si
    push di
    mov ah,09h
    lea dx,newline
    int 21h
    mov ah,09h
    lea dx,histFromAcc
    int 21h
    pop di
    pop si
    pop ax
    call printNumber

    call printPeerNameFromAX
    jmp histNextSlot

histNextSlot:
    inc di
    jmp histWalkLoop

histWalkDone:

    mov ah,09h
    lea dx,histSepLine
    int 21h

    call pause
    jmp userPanel

