; =====================================================
; PROCEDURE: printPeerNameFromAX
; -------------------------------------------------------
; Input:  AX = peer account number to search for
; Searches accountNo_arr for AX, then prints:
;   " | Name: <holder name>"
; Uses BP to protect AX across int 21h calls.
; Preserves: all registers
; =====================================================
printPeerNameFromAX proc near

    push ax
    push bx
    push cx
    push dx
    push si
    push di
    push bp

    mov bp,ax                  ; BP = peer acc no (safe across int 21h)

    mov di,0

ppn_searchLoop:

    cmp di,userCount
    jge ppn_notFound

    mov bx,di
    shl bx,1
    mov ax,accountNo_arr[bx]
    cmp ax,bp
    je  ppn_found

    inc di
    jmp ppn_searchLoop

ppn_found:

    mov ah,09h
    lea dx,histNameLabel
    int 21h

    ; Print name from userName_arr slot DI
    mov ax,di
    mov cx,20
    mul cx
    mov si,ax
    lea dx,userName_arr
    add dx,si
    mov ah,09h
    int 21h

    jmp ppn_done

ppn_notFound:

    ; peer not in DB - print nothing extra

ppn_done:

    pop bp
    pop di
    pop si
    pop dx
    pop cx
    pop bx
    pop ax
    ret

printPeerNameFromAX endp

end main
