; =====================================================
; PROCEDURE: flushKbBuffer
; -------------------------------------------------------
; Drains any leftover keystrokes from the DOS keyboard
; buffer before a masked PIN read begins.
;
; Root-cause context:
;   When the user selects a menu option (e.g. '6') via
;   int 21h/ah=01h, DOS echoes the character but the
;   ENTER key the user pressed to confirm is NOT always
;   consumed.  In EMU8086, the residual ENTER (0x0D)
;   sits in the BIOS keyboard buffer.  The very first
;   int 21h/ah=08h inside readMaskedPin then reads that
;   ENTER instead of the first PIN digit, shifting all
;   subsequent digits by one position and producing a
;   corrupted PIN value.
;
;   Fix: poll int 16h/ah=01h (keyboard status check).
;   If a key is waiting, read and discard it with
;   int 16h/ah=00h.  Repeat until the buffer is empty.
;   int 16h is the BIOS keyboard service; it does NOT
;   touch DS, DX, SI, DI, or segment registers -- safe
;   to call any time.
; =====================================================
flushKbBuffer proc near

    push ax

fkb_check:
    mov ah,01h
    int 16h                   ; ZF=1 if buffer empty, ZF=0 if key waiting
    jz  fkb_done              ; buffer empty -> done

    mov ah,00h
    int 16h                   ; read and discard the waiting key
    jmp fkb_check             ; check again

fkb_done:
    pop ax
    ret

flushKbBuffer endp

; =====================================================
; PROCEDURE: appendHistory
; -------------------------------------------------------
; Appends one transaction record for a given user.
; Reads from scratch variables before calling:
;   hist_userIdx  dw  - which user (0-based index)
;   hist_type     db  - 'D','W','T','R'
;   hist_amt      dw  - amount
;   hist_peer     dw  - peer account number (0 if none)
;
; Algorithm:
;   slot  = histCount_arr[user]          (0..9, wraps)
;   flat  = user*MAX_HIST + slot
;   historyType_arr[flat]     = type
;   historyAmt_arr [flat*2]   = amt
;   historyPeer_arr[flat*2]   = peer
;   histCount_arr[user]++ (capped at MAX_HIST via mod)
;
; Preserves: all registers (full push/pop)
; =====================================================
appendHistory proc near

    push ax
    push bx
    push cx
    push dx
    push si
    push di

    ; ---- Load user index into AX ----
    mov ax,hist_userIdx       ; AX = user index U

    ; ---- compute U * MAX_HIST ----
    mov cx,MAX_HIST
    mul cx                    ; AX = U * 10   (DX destroyed, ok)

    ; ---- add current slot index ----
    mov bx,hist_userIdx       ; BX = U (restore; AX was clobbered by mul)
    shl bx,1                  ; BX = word offset into histCount_arr
    mov cx,histCount_arr[bx]  ; CX = histCount_arr[U]  (slot 0..9)
    add ax,cx                 ; AX = flat index = U*10 + slot

    ; ---- store type (byte array, direct index) ----
    mov si,ax                 ; SI = flat byte index
    mov dl,hist_type
    mov historyType_arr[si],dl

    ; ---- store amt and peer (word arrays, *2) ----
    shl si,1                  ; SI = flat word offset
    mov dx,hist_amt
    mov historyAmt_arr[si],dx
    mov dx,hist_peer
    mov historyPeer_arr[si],dx

    ; ---- bump histCount_arr[U], cap at MAX_HIST ----
    mov bx,hist_userIdx
    shl bx,1                  ; word offset
    mov ax,histCount_arr[bx]
    inc ax
    cmp ax,MAX_HIST
    jl  ah_noWrap
    mov ax,0                  ; wrap back to slot 0 (ring buffer)
ah_noWrap:
    mov histCount_arr[bx],ax

    pop di
    pop si
    pop dx
    pop cx
    pop bx
    pop ax
    ret

appendHistory endp

; =====================================================
; PROCEDURE: readMaskedPin
; -------------------------------------------------------
; Reads exactly 4 masked digits ('*' echo) and returns
; the numeric PIN value in pinTemp (dw).
;
; [FIX-1] Root-cause explanation:
;   The original code used "mul dx" to multiply the
;   running total by 10.  "mul dx" = unsigned AX * DX.
;   But AX has ALREADY been loaded with the running
;   total and DX was expected to be 10.  The problem:
;   int 21h / ah=02h (print '*') DESTROYS DX (DOS uses
;   DX as the character to print and AX as the service
;   selector).  So when mul dx executes, DX is garbage
;   left by int 21h -- not 10.  The fix is:
;     1. Use a memory variable (pinTemp) as the
;        accumulator so AX corruption by int 21h is
;        harmless to the running total.
;     2. Use CX (not DX) as the multiplier = 10, since
;        CX is the loop counter and is not clobbered by
;        int 21h / ah=02h or ah=08h.
; =====================================================
readMaskedPin proc near

    push ax
    push bx
    push cx
    push dx

    mov pinTemp,0             ; clear accumulator
    mov bx,4                  ; loop 4 digits

rmp_loop:
    cmp bx,0
    je  rmp_done

    ; --- read one key (no echo) ---
    mov ah,08h
    int 21h                   ; AL = key char  (AX clobbered by DOS)
    ; Save digit BEFORE int 21h for echo destroys AL
    push ax                   ; save raw key

    ; --- echo '*' ---
    mov dl,'*'
    mov ah,02h
    int 21h                   ; DX, AX clobbered -- OK, digit is on stack

    ; --- recover digit ---
    pop ax                    ; AL = original key
    sub al,48                 ; AL = digit value 0-9
    mov ah,0                  ; AX = digit value

    ; --- accumulate: pinTemp = pinTemp * 10 + digit ---
    push ax                   ; save digit

    mov ax,pinTemp
    mov cx,10
    mul cx                    ; AX = pinTemp * 10 (CX=10 never touched by DOS)
    mov pinTemp,ax            ; store back

    pop ax                    ; AL = digit
    add pinTemp,ax            ; pinTemp += digit

    dec bx
    jmp rmp_loop

rmp_done:
    pop dx
    pop cx
    pop bx
    pop ax
    ret

readMaskedPin endp

