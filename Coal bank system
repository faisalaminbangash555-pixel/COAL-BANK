; =====================================================
; PROCEDURE: printNumber
; Input:  AX = unsigned 16-bit value to print
; Prints decimal digits. Safe: saves all regs.
; =====================================================
printNumber proc near

    push ax
    push bx
    push cx
    push dx

    mov bx,10
    mov cx,0

pn_divide:
    mov dx,0
    div bx
    push dx
    inc cx
    cmp ax,0
    jne pn_divide

pn_print:
    pop dx
    add dl,48
    mov ah,02h
    int 21h
    loop pn_print

    pop dx
    pop cx
    pop bx
    pop ax
    ret

printNumber endp

