    ; --------------------------------------------------
    ; FIRST-TIME ADMIN PIN SETUP
    ; --------------------------------------------------

    cmp isAdminPinSet,1
    je  start

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ah,09h
    lea dx,adminPromptMsg
    int 21h

    call flushKbBuffer        ; drain any leftover keystrokes before PIN entry
    call readMaskedPin        ; result in pinTemp
    mov ax,pinTemp
    mov adminPin,ax
    mov isAdminPinSet,1

    mov ah,09h
    lea dx,newline
    int 21h

    mov ah,09h
    lea dx,successMsg
    int 21h

    call pause

; =====================================================
; MAIN MENU ROUTER
; =====================================================

start:

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ah,09h
    lea dx,mainMenu
    int 21h

    mov ah,01h
    int 21h

    mov choice,al

    cmp choice,'1'
    je  doRegister

    cmp choice,'2'
    je  doLogin

    cmp choice,'3'
    je  exitProgram

    cmp choice,'4'
    je  adminMode

    jmp start

; =====================================================
; REGISTER ACCOUNT
; =====================================================

doRegister:

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ax,userCount
    cmp ax,MAX_USERS
    jae systemFull

    ; --- Read Name ---
    mov ah,09h
    lea dx,nameMsg
    int 21h

    lea si,tempName
    mov cx,19

nameLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  nameDone
    cmp cx,0
    je  nameDone
    mov [si],al
    inc si
    dec cx
    jmp nameLoop

nameDone:
    mov byte ptr [si],'$'

    ; --- Read Account Number ---
    mov ah,09h
    lea dx,accMsg
    int 21h

    mov bx,0

accLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  accDone
    sub al,48
    mov ah,0
    push ax
    mov ax,bx
    mov cx,10
    mul cx
    mov bx,ax
    pop ax
    add bx,ax
    jmp accLoop

accDone:

    ; --- Duplicate check ---
    mov cx,userCount
    cmp cx,0
    je  noDuplicate

    mov si,0

dupCheckLoop:
    mov di,si
    shl di,1
    cmp bx,accountNo_arr[di]
    je  dupAccount
    inc si
    loop dupCheckLoop

noDuplicate:

    ; Store account number
    mov si,userCount
    shl si,1
    mov accountNo_arr[si],bx

    ; --- Read PIN (FIXED via readMaskedPin) ---
    mov ah,09h
    lea dx,pinMsg
    int 21h

    call flushKbBuffer        ; drain leftover ENTER from account number input
    call readMaskedPin        ; [FIX-1] PIN now read correctly into pinTemp

    ; Store PIN
    mov ax,pinTemp
    mov si,userCount
    shl si,1
    mov userPin_arr[si],ax

    ; --- Read Initial Deposit ---
    mov ah,09h
    lea dx,initialDepositMsg
    int 21h

    mov bx,0

initLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  initDone
    sub al,48
    mov ah,0
    push ax
    mov ax,bx
    mov cx,10
    mul cx
    mov bx,ax
    pop ax
    add bx,ax
    jmp initLoop

initDone:

    ; Store balance
    mov si,userCount
    shl si,1
    mov balance_arr[si],bx

    ; --- Append initial deposit to history ---
    ; [FIX-2] uses appendHistory so we get a real record
    mov ax,userCount
    mov hist_userIdx,ax
    mov hist_type,'D'
    mov hist_amt,bx
    mov hist_peer,0
    call appendHistory

    ; --- Copy name into userName_arr slot ---
    mov ax,userCount
    mov cx,20
    mul cx
    mov di,ax

    lea si,tempName

copyName:
    mov al,[si]
    mov userName_arr[di],al
    cmp al,'$'
    je  copyNameDone
    inc si
    inc di
    jmp copyName

copyNameDone:

    inc userCount

    mov ah,09h
    lea dx,successMsg
    int 21h

    call pause
    jmp start

systemFull:
    mov ah,09h
    lea dx,systemFullMsg
    int 21h
    call pause
    jmp start

dupAccount:
    mov ah,09h
    lea dx,duplicateMsg
    int 21h
    call pause
    jmp start

; =====================================================
; LOGIN
; [FIX-3] Architecture confirmed correct:
;   1. Read account number
;   2. Find user index -> currentUserIndex
;   3. Prompt PIN
;   4. Compare PIN via readMaskedPin (now correct)
;   5. Only on match -> jmp userPanel
; =====================================================

doLogin:

    mov attempts,0

loginTop:

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ah,09h
    lea dx,loginAccMsg
    int 21h

    mov bx,0

loginAccLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  loginAccDone
    sub al,48
    mov ah,0
    push ax
    mov ax,bx
    mov cx,10
    mul cx
    mov bx,ax
    pop ax
    add bx,ax
    jmp loginAccLoop

loginAccDone:

    mov cx,userCount
    cmp cx,0
    je  loginFail

    mov si,0

loginSearchLoop:
    mov di,si
    shl di,1
    cmp bx,accountNo_arr[di]
    je  loginAccFound
    inc si
    loop loginSearchLoop
    jmp loginFail

loginAccFound:

    mov currentUserIndex,si

    ; --- Prompt and read PIN (FIXED) ---
    mov ah,09h
    lea dx,loginPinMsg
    int 21h

    call flushKbBuffer        ; drain leftover ENTER from account number input
    call readMaskedPin        ; [FIX-1] result in pinTemp

    ; --- Compare PIN ---
    mov si,currentUserIndex
    shl si,1                  ; word offset
    mov ax,pinTemp            ; AX = entered PIN (numeric)
    cmp ax,userPin_arr[si]    ; compare against stored PIN
    jne loginFail             ; [FIX-3] mismatch -> fail immediately

    ; --- Login successful ---
    mov attempts,0

    call clearScreen

    mov ah,09h
    lea dx,welcomeMsg
    int 21h

    mov ah,09h
    lea dx,holderText
    int 21h

    mov ax,currentUserIndex
    mov cx,20
    mul cx
    mov si,ax
    lea dx,userName_arr
    add dx,si
    mov ah,09h
    int 21h

    call pause
    jmp userPanel

loginFail:

    inc attempts
    cmp attempts,3
    je  loginBlocked

    mov ah,09h
    lea dx,loginFailMsg
    int 21h
    call pause
    jmp start

loginBlocked:

    mov ah,09h
    lea dx,blockedMsg
    int 21h
    call pause
    jmp exitProgram

