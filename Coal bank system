    cmp di,userCount
    jge listAccDone

    mov ah,09h
    lea dx,ledgerRowPrefix
    int 21h

    mov si,di
    shl si,1
    mov ax,accountNo_arr[si]
    call printNumber

    mov ah,09h
    lea dx,transferAccText
    int 21h

    push di
    mov ax,di
    mov cx,20
    mul cx
    mov si,ax
    lea dx,userName_arr
    add dx,si
    mov ah,09h
    int 21h
    pop di

    inc di
    jmp listAccLoop

listAccDone:

    ; Show sender's live balance
    mov ah,09h
    lea dx,senderBalMsg
    int 21h

    mov si,currentUserIndex
    shl si,1
    mov ax,balance_arr[si]
    call printNumber

    ; Prompt for receiver account number
    mov ah,09h
    lea dx,transferAccMsg
    int 21h

    mov bx,0

recAccLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  recAccDone
    sub al,48
    mov ah,0
    push ax
    mov ax,bx
    mov cx,10
    mul cx
    mov bx,ax
    pop ax
    add bx,ax
    jmp recAccLoop

recAccDone:

    ; Validate receiver
    mov cx,userCount
    cmp cx,0
    je  doInvalidRec

    mov di,0

findRecLoop:
    cmp di,userCount
    jge doInvalidRec

    mov si,di
    shl si,1
    cmp bx,accountNo_arr[si]
    je  recFound

    inc di
    jmp findRecLoop

recFound:

    cmp di,currentUserIndex
    je  doSelfTransfer

    ; Prompt for amount
    mov ah,09h
    lea dx,transferMsg
    int 21h

    mov bx,0

trAmtLoop:
    mov ah,01h
    int 21h
    cmp al,13
    je  trAmtDone
    sub al,48
    mov ah,0
    push ax
    mov ax,bx
    mov cx,10
    mul cx
    mov bx,ax
    pop ax
    add bx,ax
    jmp trAmtLoop

trAmtDone:

    ; Check sender balance
    mov si,currentUserIndex
    shl si,1
    mov ax,balance_arr[si]
    cmp ax,bx
    jb  doInsufficientTr

    ; Deduct from sender
    sub ax,bx
    mov balance_arr[si],ax

    ; Add to receiver
    ; DI = receiver index
    mov si,di
    shl si,1
    mov ax,balance_arr[si]
    add ax,bx
    mov balance_arr[si],ax

    ; Get receiver account number for sender history peer
    mov si,di
    shl si,1
    mov ax,accountNo_arr[si]   ; AX = receiver acc no (for sender's peer)

    ; Append sender history  (T = Sent)
    mov cx,currentUserIndex
    mov hist_userIdx,cx
    mov hist_type,'T'
    mov hist_amt,bx
    mov hist_peer,ax           ; peer = receiver acc no
    call appendHistory

    ; Get sender account number for receiver history peer
    mov si,currentUserIndex
    shl si,1
    mov ax,accountNo_arr[si]   ; AX = sender acc no (for receiver's peer)

    ; Append receiver history (R = Received)
    mov hist_userIdx,di
    mov hist_type,'R'
    mov hist_amt,bx
    mov hist_peer,ax           ; peer = sender acc no
    call appendHistory

    mov ah,09h
    lea dx,successMsg
    int 21h
    call pause
    jmp userPanel

doInsufficientTr:
    mov ah,09h
    lea dx,insufficientMsg
    int 21h
    call pause
    jmp userPanel

doInvalidRec:
    mov ah,09h
    lea dx,invalidRecMsg
    int 21h
    call pause
    jmp userPanel

doSelfTransfer:
    mov ah,09h
    lea dx,selfTransferMsg
    int 21h
    call pause
    jmp userPanel

