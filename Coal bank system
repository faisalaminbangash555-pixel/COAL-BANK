    mov ah,09h
    lea dx,adminLoginMsg
    int 21h

    call flushKbBuffer        ; drain leftover ENTER from menu choice
    call readMaskedPin        ; result in pinTemp

    mov ax,pinTemp
    cmp ax,adminPin
    jne adminFail

