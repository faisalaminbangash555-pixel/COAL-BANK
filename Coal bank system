; =====================================================
; [FIX-2] 2-D TRANSACTION HISTORY ARRAYS
;
;   Layout: 5 users x 10 transactions = 50 slots
;
;   Byte index for user U, transaction T:
;       historyType_arr [ U*10 + T ]
;
;   Word index (byte offset) for user U, transaction T:
;       historyAmt_arr  [ (U*10 + T) * 2 ]
;       historyPeer_arr [ (U*10 + T) * 2 ]
;
;   histCount_arr[U] = how many transactions user U has.
;   When histCount_arr[U] == MAX_HIST (10) the slot wraps
;   around to index 0 so the oldest entry is overwritten.
; =====================================================

HIST_SLOTS equ MAX_USERS * MAX_HIST          ; = 50

historyType_arr  db HIST_SLOTS dup('N')      ; 50 bytes
historyAmt_arr   dw HIST_SLOTS dup(0)        ; 100 bytes
historyPeer_arr  dw HIST_SLOTS dup(0)        ; 100 bytes
histCount_arr    dw MAX_USERS  dup(0)        ; 10 bytes  (count per user, max 10)

